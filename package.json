{
  "name": "sunol-flowlab-vr",
  "version": "0.0.0",
  "private": true,
  "description": "A phenomenological coagulation experiment for WebXR and desktop spectators.",
  "type": "module",
  "engines": {
    "node": ">=24.12.0 <25",
    "npm": ">=11.18.0 <12"
  },
  "packageManager": "npm@11.18.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:https": "vite --host 0.0.0.0 --mode https",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "test": "node --test --test-isolation=none tests/*.test.mjs && vitest run",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "capture:review": "node scripts/capture-batch-03-review.mjs",
    "capture:apparatus": "node scripts/capture-batch-03-review.mjs --apparatus-only",
    "benchmark": "vitest run src/sim/benchmark.cli.test.ts --reporter=dot",
    "acceptance:03d": "vitest run src/sim/acceptance.cli.test.ts --reporter=dot",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/xr": "6.6.30",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.165.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.165.0",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
